# ============================================================
# AWS — versão Bedrock (sem chave OpenAI)
# Em produção (EKS) as credenciais vêm via IRSA — não precisa configurar aqui.
# Em desenvolvimento local, configure o AWS CLI: aws configure
# ============================================================
AWS_REGION=us-east-1

# LLM: Claude 3 Haiku (cheapest Claude on Bedrock)
BEDROCK_LLM_MODEL=anthropic.claude-3-haiku-20240307-v1:0

# Embeddings: Titan Text v2 (multilingual, $0.00002/1K tokens)
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_EMBED_DIMENSIONS=1024

# ============================================================
# Database — RDS PostgreSQL (local dev usa Docker, prod usa RDS)
# ============================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/wiki_rag
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/wiki_rag

# ============================================================
# Ingestion
# ============================================================
WIKI_CLONE_DIR=/tmp/wiki_clones

# ============================================================
# App
# ============================================================
APP_ENV=development
LOG_LEVEL=INFO
